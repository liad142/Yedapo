# ── Supabase (required) ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=

# ── Upstash Redis (required) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Google Gemini AI (required) ──
GOOGLE_GEMINI_API_KEY=

# ── Deepgram (required for transcription) ──
DEEPGRAM_API_KEY=

# ── Mistral / Voxtral (optional) ──
MISTRAL_API_KEY=

# ── YouTube Data API (optional) ──
YOUTUBE_API_KEY=

# ── Google OAuth for YouTube token refresh (optional) ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Podcast Index API (optional) ──
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=

# ── Apple Podcasts (optional) ──
APPLE_PODCASTS_BEARER_TOKEN=

# ── PostHog Analytics (optional) ──
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=

# ── Resend Email (optional) ──
RESEND_API_KEY=

# ── Telegram Notifications (optional) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=

# ── Cron Jobs (optional) ──
CRON_SECRET=

# ── Admin (optional) ──
ADMIN_EMAILS=

# ── App URL (optional, defaults to localhost:3000) ──
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Logging (optional, defaults: debug in dev, warn in prod)
LOG_LEVEL=

# Test runner (dev/test only)
TEST_BASE_URL=http://localhost:3000

# Admin alerting (optional — Telegram chat ID for cron failure alerts)
ADMIN_TELEGRAM_CHAT_ID=

# Monitoring (optional — Bearer token for /api/health full details)
MONITORING_SECRET=
